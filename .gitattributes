# ---------------------------------------------------------------------------
# Default: let Git auto-detect text files and normalize them to LF in the repo.
# On checkout, Git will convert to the platform's native line endings only if
# core.autocrlf is set; otherwise it stays LF. This matches our .editorconfig
# (`end_of_line = lf`) and prevents `dotnet format --verify-no-changes` from
# flapping in CI when a Windows dev commits CRLF by accident.
# ---------------------------------------------------------------------------
* text=auto eol=lf

# ---------------------------------------------------------------------------
# Source — explicit LF to be safe even if `text=auto` misclassifies
# ---------------------------------------------------------------------------
*.cs           text eol=lf diff=csharp
*.csproj       text eol=lf
*.props        text eol=lf
*.targets      text eol=lf
*.sln          text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.config       text eol=lf

*.ts           text eol=lf
*.tsx          text eol=lf
*.js           text eol=lf
*.jsx          text eol=lf
*.mjs          text eol=lf
*.cjs          text eol=lf
*.css          text eol=lf
*.scss         text eol=lf
*.html         text eol=lf
*.svg          text eol=lf

*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf

# ---------------------------------------------------------------------------
# Shell and CI files — must be LF on every platform, including Windows.
# Husky hooks fail with `bad interpreter` if checked out as CRLF.
# ---------------------------------------------------------------------------
*.sh           text eol=lf
.husky/*       text eol=lf
Dockerfile     text eol=lf
*.dockerfile   text eol=lf
.editorconfig  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.dockerignore  text eol=lf
.prettierrc    text eol=lf
.prettierignore text eol=lf

# ---------------------------------------------------------------------------
# Files that must keep CRLF (some Windows-only tooling cares).
# Currently none in this repo, but if you add a `.bat` or `.cmd` later:
# ---------------------------------------------------------------------------
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# ---------------------------------------------------------------------------
# Binary files — Git must not try to diff or normalize these
# ---------------------------------------------------------------------------
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.webp         binary
*.avif         binary
*.pdf          binary
*.zip          binary
*.gz           binary
*.tar          binary
*.7z           binary

# Fonts
*.woff         binary
*.woff2        binary
*.ttf          binary
*.eot          binary
*.otf          binary

# .NET build artifacts (also gitignored, but belt-and-braces)
*.dll          binary
*.exe          binary
*.pdb          binary
*.snk          binary

# ---------------------------------------------------------------------------
# Lockfiles — text, but never useful to view as a diff in PRs
# ---------------------------------------------------------------------------
package-lock.json   text eol=lf linguist-generated=true
yarn.lock           text eol=lf linguist-generated=true
pnpm-lock.yaml      text eol=lf linguist-generated=true

# ---------------------------------------------------------------------------
# Generated / vendored — exclude from GitHub language stats and PR diff view
# ---------------------------------------------------------------------------
frontend/components/ui/**   linguist-generated=true
**/Migrations/**            linguist-generated=true
